FROM python:3.14-slim

COPY --from=ghcr.io/astral-sh/uv:0.11.14 /uv /uvx /bin/

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libc6-dev \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

ENV PYO3_USE_ABI3_FORWARD_COMPATIBILITY=1

# Create non-root user
RUN useradd -m -u 10001 appuser && \
    mkdir -p /opt/app/services/moddingway /opt/app/tests/moddingway && \
    chown -R appuser:appuser /opt/app
USER appuser

# Service root
WORKDIR /opt/app/services/moddingway

# Copy dependency declarations
COPY --chown=appuser:appuser services/moddingway/pyproject.toml services/moddingway/uv.lock ./

# Install dependencies
RUN --mount=type=cache,target=/home/appuser/.cache/uv,uid=10001,gid=10001 \
    uv sync --frozen --all-groups --no-install-project --link-mode=copy

COPY --chown=appuser:appuser services/moddingway/ ./

# Install the project
RUN --mount=type=cache,target=/home/appuser/.cache/uv,uid=10001,gid=10001 \
    uv sync --frozen --all-groups --link-mode=copy

# Copy tests, mirrors repo layout
COPY --chown=appuser:appuser tests/moddingway/ /opt/app/tests/moddingway/

WORKDIR /opt/app/tests/moddingway
ENTRYPOINT ["uv", "run", "--project", "/opt/app/services/moddingway", "pytest"]
CMD ["unit"]
